<?xml version="1.0" encoding="UTF-8"?>
<xsd:schema version="000-01" xmlns:xsd="http://www.w3.org/2001/XMLSchema" vc:minVersion="1.1"
    xmlns="http://www.asd-europe.org/s-series/s2000m"
    xmlns:vc="http://www.w3.org/2007/XMLSchema-versioning"
    xmlns:value="http://www.asd-europe.org/spec/validValues"    
    xmlns:unit="http://www.asd-europe.org/spec/validValues"
    targetNamespace="http://www.asd-europe.org/s-series/s2000m"> 
    
    <xsd:annotation>
        <xsd:documentation>Issue number: 6.1</xsd:documentation>
        <xsd:documentation>Issue date: 2017-08-24</xsd:documentation>
        <xsd:documentation>XML schema release number: 002-00</xsd:documentation>
        <xsd:documentation>XML schema release date: 2017-10-06</xsd:documentation>
        <xsd:documentation>URL: http://www.s2000m.org</xsd:documentation>
        <xsd:documentation>Root element: pnoipd</xsd:documentation>
        <xsd:documentation>Copyright:
            Copyright (C) 2017 by each of the following organizations:
