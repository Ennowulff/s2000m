            3.  Revisions to this document may occur after its issuance.  The user is responsible for determining if revisions to the material contained in this document have occurred and are applicable. 
        </xsd:documentation>
    </xsd:annotation>
    
    <xsd:import schemaLocation="s2000m_6-1_valid_values.xsd" namespace="http://www.asd-europe.org/spec/validValues"/>
    
    <xsd:element name="pnoipd" type="message"/>
    
    <xsd:complexType name="message">
        <xsd:annotation>
            <xsd:appinfo>SX001G:Message</xsd:appinfo>
        </xsd:annotation>
        <xsd:sequence>
            <!--UML-Attributes-->
            <xsd:element name="drs" type="messageIdentifier" minOccurs="1" nillable="true"/>
            <xsd:element name="drd" type="messageCreationDate" minOccurs="1" nillable="true"/>
            <xsd:element name="lge" type="messageLanguage" minOccurs="1" nillable="true"/>
            <xsd:element name="mcs" type="messageContentStatus" minOccurs="1" nillable="true"/>
            <xsd:element name="rmk" type="remarkText" minOccurs="0" nillable="true"/>
            <!--UML-EmbAssocs-->
            <xsd:element name="tod" type="messageSender" minOccurs="1"/>
            <xsd:element name="add" type="messageReceiver" minOccurs="1"/>
            <xsd:element name="msgContext" type="messageContext" minOccurs="1" nillable="true"/>
            <!--UML-CompAssocs-->
            <xsd:element name="msgContent" type="partOrientedProvisioningProjectContent" minOccurs="1" nillable="true"/>
        </xsd:sequence>        
        <xsd:attribute name="crud" type="crudCodeValues" default="I"/>
    </xsd:complexType>  
        
    <xsd:complexType name="partOrientedProvisioningProjectContent">
        <xsd:annotation>
            <xsd:appinfo>SX001G:PartOrientedProvisioningProjectContent</xsd:appinfo>
        </xsd:annotation>
        <xsd:sequence>
            <!--UML-CompAssocs-->
            <xsd:element name="prc" type="partInProvisioningProject" minOccurs="0" maxOccurs="unbounded" nillable="true"/>
            <xsd:element name="pas" type="hardwarePartAsDesigned" minOccurs="0" maxOccurs="unbounded" nillable="true"/> 
        </xsd:sequence>
        <xsd:attribute name="crud" type="crudCodeValues" default="I"/>
    </xsd:complexType>
    
    <!-- ===============================  UML CLASSES ======================================= -->
    
    <xsd:complexType name="hardwarePartAsDesigned">
        <xsd:annotation>
            <xsd:appinfo>SX001G:HardwarePartAsDesigned</xsd:appinfo>
        </xsd:annotation>
        <xsd:sequence>
            <!--UML-Attributes-->
            <xsd:element name="pid" type="partIdentifier"/>
            <xsd:element name="dfp" type="partName" minOccurs="0" nillable="true"/>
            <!--UML-AttGroups-->
            <xsd:group ref="hardwarePartAsDesignedDesignData"/>
            <xsd:group ref="hardwarePartAsDesignedSupportData"/>
            <xsd:group ref="hardwarePartAsDesignedControlledItemData"/>
            <xsd:group ref="hardwarePartAsDesignedCommerceData"/>
            <xsd:group ref="hardwarePartAsDesignedCustomerFurnishedData"/>
            <xsd:group ref="natoCodification"/>
            <!--UML-EmbAssocs-->
            <xsd:element name="rpp" type="replacementPartRelationship" nillable="true" minOccurs="0"/>
            <xsd:element name="ageRef" type="partRequirementsDefinitionReference" nillable="true" minOccurs="0"/>
            <xsd:element name="cti" type="hardwarePartContainer" nillable="true" minOccurs="0"/>
        </xsd:sequence>
        <xsd:attribute name="crud" type="crudCodeValues" default="I"/>
    </xsd:complexType>   
    
    <xsd:complexType name="hardwarePartContainer">
        <xsd:annotation>
            <xsd:appinfo>SX001G:HardwarePartContainer</xsd:appinfo>
        </xsd:annotation>
        <xsd:sequence>
            <!--UML-EmbAssocs-->
            <xsd:element name="pidRef" type="partAsDesignedReference"/>
        </xsd:sequence>
        <xsd:attribute name="crud" type="crudCodeValues" default="I"/>
    </xsd:complexType>
    
    <xsd:complexType name="messageContext">
        <xsd:annotation>
            <xsd:appinfo>SX001G:MessageContext</xsd:appinfo>
        </xsd:annotation>
        <xsd:sequence>
            <!--UML-EmbAssocs-->
            <xsd:group ref="messageContextItemSelect"/>
        </xsd:sequence>
        <xsd:attribute name="crud" type="crudCodeValues" default="I"/>
    </xsd:complexType>
    
    <xsd:complexType name="messageReceiver">
        <xsd:annotation>
            <xsd:appinfo>SX001G:MessageReceiver</xsd:appinfo>
        </xsd:annotation>
        <xsd:sequence>
            <!--UML-Interfaces-->
            <xsd:group ref="messagePartySelect"/>
        </xsd:sequence>
        <xsd:attribute name="crud" type="crudCodeValues" default="I"/>
    </xsd:complexType>
    
    <xsd:complexType name="messageSender">
        <xsd:annotation>
            <xsd:appinfo>SX001G:MessageSender</xsd:appinfo>
        </xsd:annotation>
        <xsd:sequence>
            <!--UML-Interfaces-->
            <xsd:group ref="messagePartySelect"/>
        </xsd:sequence>
        <xsd:attribute name="crud" type="crudCodeValues" default="I"/>
    </xsd:complexType>
    
    <xsd:complexType name="partInProvisioningProject">
        <xsd:annotation>
            <xsd:appinfo>SX001G:PartInProvisioningProject</xsd:appinfo>
        </xsd:annotation>
        <xsd:sequence>
            <!--UML-Attributes-->
            <xsd:element name="pidRef" type="partAsDesignedReference"/>
            <xsd:element name="tqy" type="totalQuantityInProvisioningProject" nillable="true" minOccurs="0"/>
            <!--UML-AttGroups-->
            <xsd:group ref="sparesRecommendation"/>
        </xsd:sequence>
        <xsd:attribute name="crud" type="crudCodeValues" default="I"/>
    </xsd:complexType>
    
    <xsd:complexType name="provisioningProject">
        <xsd:annotation>
            <xsd:appinfo>SX001G:ProvisioningProject</xsd:appinfo>
        </xsd:annotation>
        <xsd:sequence>
            <!--UML-Attributes-->
            <xsd:element name="ipp" type="provisioningProjectIdentifier"/>
            <xsd:element name="ips" type="provisioningProjectSubject" nillable="true" minOccurs="0"/>
            <xsd:element name="fid" type="provisioningProjectTypeOfPresentation" nillable="true" minOccurs="0"/>
            <!--UML-EmbAssocs-->
            <xsd:element name="ippDel" type="provisioningProjectDelivery" nillable="true" minOccurs="0"/>
            <!--UML-Interfaces-->
            <xsd:group ref="provisioningProjectContextItem"/>
        </xsd:sequence>
        <xsd:attribute name="crud" type="crudCodeValues" default="I"/>
    </xsd:complexType>
    
    <xsd:complexType name="provisioningProjectDelivery">
        <xsd:annotation>
            <xsd:appinfo>SX001G:provisioningProjectDelivery</xsd:appinfo>
        </xsd:annotation>
        <xsd:sequence>
            <!--UML-Attributes-->
            <xsd:element name="iss" type="provisioningProjectStatus"/>
        </xsd:sequence>
        <xsd:attribute name="crud" type="crudCodeValues" default="I"/>
    </xsd:complexType>
    
    <xsd:complexType name="replacementPartRelationship">
        <xsd:annotation>
            <xsd:appinfo>SX001G:ReplacementPartRelationship</xsd:appinfo>
        </xsd:annotation>
        <xsd:sequence>
            <!--UML-EmbAssocs-->
            <xsd:element name="pidRef" type="partAsDesignedReference"/>
            <!--UML-Interfaces-->
            <xsd:group ref="changeControlledItem"/>
        </xsd:sequence>
        <xsd:attribute name="crud" type="crudCodeValues" default="I"/>
    </xsd:complexType>	
    
    
    <!-- ============================== UML INTERFACES ====================================== -->
    
    <xsd:group name="changeControlledItem">
        <xsd:annotation>
            <xsd:appinfo>SX001G:ChangeControlledItem</xsd:appinfo>
        </xsd:annotation>
        <xsd:sequence>
            <!--UML-EmbAssocs-->
            <xsd:element name="chgRef" type="changeAuthorizationReference" minOccurs="0" maxOccurs="unbounded" nillable="true"/>
        </xsd:sequence>
    </xsd:group>  
    
    <xsd:group name="messageContextItemSelect">
        <xsd:annotation>
            <xsd:appinfo>SX001G:MessageContextItemSelect</xsd:appinfo>
        </xsd:annotation>
        <xsd:choice>         
            <xsd:element name="ippn" type="provisioningProject" minOccurs="0"/>
        </xsd:choice>
    </xsd:group> 
    
    <xsd:group name="messagePartySelect">
        <xsd:annotation>
            <xsd:appinfo>SX001G:MessagePartySelect</xsd:appinfo>
        </xsd:annotation>
        <xsd:choice>
            <xsd:element name="orgRef" type="organizationReference" minOccurs="0"/>
        </xsd:choice>
    </xsd:group> 
    
    <xsd:group name="provisioningProjectContextItem">
        <xsd:annotation>
            <xsd:appinfo>SX0001:ProvisioningProjectContextItem</xsd:appinfo>
        </xsd:annotation>
        <xsd:choice>
            <xsd:element name="moiRef" type="productReference" nillable="true" minOccurs="0"/>
        </xsd:choice>
    </xsd:group>
    
    <xsd:group name="serviceApplicabilityItem">
        <xsd:annotation>
            <xsd:appinfo>SX0001:ServiceApplicabilityItem</xsd:appinfo>
        </xsd:annotation>
        <xsd:choice>
            <!--UML-EmbAssocs-->
            <xsd:element name="srvRef" type="userReference" minOccurs="0" nillable="true"/>
        </xsd:choice>
    </xsd:group>
    
    <!-- =========================  UML ATTRIBUTE GROUPS =================================== -->
    
    <xsd:group name="hardwarePartAsDesignedCommerceData">
        <xsd:annotation>
            <xsd:appinfo>SX0001:HardwarePartAsDesignedCommerceData</xsd:appinfo>
        </xsd:annotation>
        <xsd:sequence>
            <!--UML-Attributes-->
            <xsd:element name="msq" type="minimumSalesQuantity" nillable="true" minOccurs="0"/>
            <xsd:element name="uop" type="hardwarePartUnitOfIssuePrice" nillable="true" minOccurs="0"/>
            <xsd:element name="top" type="typeOfPrice" nillable="true" minOccurs="0"/>
            <!--UML-AttGroups-->
            <xsd:group ref="priceBreakData"/>
        </xsd:sequence>
    </xsd:group>
    
    <xsd:group name="hardwarePartAsDesignedControlledItemData">
        <xsd:annotation>
            <xsd:appinfo>SX0001:HardwarePartAsDesignedControlledItemData</xsd:appinfo>
        </xsd:annotation>
        <xsd:sequence>
            <!--UML-Attributes-->
            <xsd:element name="dec" type="partDemilitarizationClass" nillable="true" minOccurs="0"/>
            <xsd:element name="scc" type="securityClass" nillable="true" minOccurs="0"/>
            <xsd:element name="sic" type="partSensitiveItemClass" nillable="true" minOccurs="0"/>
            <xsd:element name="psc" type="hardwarePartPilferageClass" nillable="true" minOccurs="0"/>
        </xsd:sequence>
    </xsd:group>
    
    <xsd:group name="hardwarePartAsDesignedCustomerFurnishedData">
        <xsd:annotation>
            <xsd:appinfo>SX0001:HardwarePartAsDesignedCustomerFurnishedData</xsd:appinfo>
        </xsd:annotation>
        <xsd:sequence>
            <!--UML-Attributes-->
            <xsd:element name="dmc" type="inventoryManagementClass" nillable="true" minOccurs="0"/>
        </xsd:sequence>
    </xsd:group>
    
    <xsd:group name="hardwarePartAsDesignedDesignData">
        <xsd:annotation>
            <xsd:appinfo>SX001G:HardwarePartAsDesignedDesignData</xsd:appinfo>
        </xsd:annotation>
        <xsd:sequence>
            <!--UML-Attributes-->
            <xsd:element name="haz" type="hardwarePartHazardousClass" minOccurs="0" nillable="true"/>
            <xsd:element name="aul" type="authorizedLifeValue" minOccurs="0" maxOccurs="unbounded" nillable="true"/>
            <xsd:element name="sim" type="serializedItemTraceabilityRequirement" minOccurs="0" nillable="true"/>
            <xsd:element name="suu" type="hardwarePartSize" minOccurs="0" nillable="true"/>
            <xsd:element name="wuu" type="hardwarePartWeight" minOccurs="0" nillable="true"/>
            <xsd:element name="cmk" type="hardwarePartCalibrationRequirement" minOccurs="0" fixed="true" nillable="true"/>
            <xsd:element name="emi" type="hardwarePartElectromagneticIncompatible" minOccurs="0" fixed="true" nillable="true"/>
            <xsd:element name="ess" type="hardwarePartElectrostaticSensitive" minOccurs="0" fixed="true" nillable="true"/>
            <xsd:element name="ems" type="hardwarePartElectromagneticSensitive" minOccurs="0" fixed="true" nillable="true"/>
            <xsd:element name="mse" type="hardwarePartMagneticSensitive" minOccurs="0" fixed="true" nillable="true"/>
            <xsd:element name="rse" type="hardwarePartRadiationSensitive" minOccurs="0" fixed="true" nillable="true"/>               
            <xsd:element name="str" type="hardwarePartSpecialStorageRequirement" minOccurs="0" default="false" nillable="true"/>
            <xsd:element name="slt" type="hardwarePartShelfLifeType" minOccurs="0" nillable="true"/>
            <xsd:element name="slm" type="hardwarePartShelfLifeLimit" minOccurs="0" nillable="true"/>
            <xsd:element name="sla" type="hardwarePartShelfLifeLimitAction" minOccurs="0" nillable="true"/>
            <xsd:element name="tlf" type="hardwarePartTotalLifeLimit" minOccurs="0" nillable="true"/>
        </xsd:sequence>
    </xsd:group>
    
    <xsd:group name="hardwarePartAsDesignedSupportData">
        <xsd:annotation>
            <xsd:appinfo>SX001G:HardwarePartAsDesignedSupportData</xsd:appinfo>
        </xsd:annotation>
        <xsd:sequence>
            <!--UML-Attributes -->   
            <xsd:element name="spc" type="hardwarePartRepairability" minOccurs="0" nillable="true"/>
            <xsd:element name="sra" type="hardwarePartScrapRate" minOccurs="0" maxOccurs="unbounded" nillable="true"/>       
            <xsd:element name="ity" type="hardwarePartProvisioningCategory" minOccurs="0" nillable="true"/>            
            <xsd:element name="ftc" type="hardwarePartFitmentLevel" minOccurs="0" nillable="true"/>         
            <xsd:element name="tbo" type="timeBetweenOverhaul" minOccurs="0" nillable="true"/>
            <xsd:element name="tsv" type="timeBetweenScheduledShopVisits" minOccurs="0" nillable="true"/>
            <xsd:element name="crt" type="contractorRepairTurnAroundTime" minOccurs="0" nillable="true"/>
            <xsd:element name="uoi" type="hardwarePartUnitOfIssue" minOccurs="0" nillable="true"/>
            <xsd:element name="qui" type="hardwarePartQuantityPerUnitOfIssue" minOccurs="0" nillable="true"/>
            <xsd:element name="plc" type="hardwarePartPackagingRequirement" minOccurs="0" nillable="true"/>
            <xsd:element name="pso" type="hardwarePartProcurementSource" minOccurs="0" nillable="true"/>
            <xsd:element name="plt" type="hardwarePartPurchasingLeadTime" minOccurs="0" nillable="true"/>
            <xsd:element name="pic" type="hardwarePartPoolItemCandidate" minOccurs="0" nillable="true"/>
            <xsd:element name="osp" type="obsoletePart" minOccurs="0" nillable="true"/>
            <xsd:element name="spq" type="hardwarePartStandardPackageQuantity" minOccurs="0" nillable="true"/>
            <xsd:element name="spu" type="hardwarePartPackagedSize" minOccurs="0" nillable="true"/>
            <xsd:element name="wpu" type="hardwarePartPackagedWeight" minOccurs="0" nillable="true"/>
        </xsd:sequence>
    </xsd:group>
    
    <xsd:group name="natoCodification">
        <xsd:annotation>
            <xsd:appinfo>SX0001:NatoCodification</xsd:appinfo>
        </xsd:annotation>
        <xsd:sequence>
            <xsd:element name="natoCode" minOccurs="0" nillable="true">
                <xsd:complexType>
                    <xsd:sequence>
                        <!--UML-Attributes-->
                        <xsd:element name="nsn" type="natoStockNumber" nillable="true" minOccurs="0"/>
                        <xsd:element name="ain" type="natoItemName" nillable="true" minOccurs="0"/>
                        <xsd:element name="inc" type="natoItemNameCode" nillable="true" minOccurs="0"/>
                        <xsd:element name="rnc" type="referenceNumberCategory" nillable="true" minOccurs="0"/>
                        <xsd:element name="rnv" type="referenceNumberVariation" nillable="true" minOccurs="0"/>
                    </xsd:sequence>
                </xsd:complexType>
            </xsd:element>
        </xsd:sequence>
    </xsd:group>
    
    <xsd:group name="priceBreakData">
        <xsd:annotation>
            <xsd:appinfo>SX0001:PriceBreakData</xsd:appinfo>
        </xsd:annotation>
        <xsd:sequence>
            <xsd:element name="pbd" nillable="true" minOccurs="0" maxOccurs="3">
                <xsd:complexType>
                    <xsd:sequence>
                        <!--UML-Attributes-->
                        <xsd:element name="llq" type="lowerLimitSalesQuantity"/>
                        <xsd:element name="ulq" type="upperLimitSalesQuantity"/>
                        <xsd:element name="uop" type="hardwarePartUnitOfIssuePrice"/>
                    </xsd:sequence>
                </xsd:complexType>
            </xsd:element>
        </xsd:sequence>
    </xsd:group>
    
    <xsd:group name="sparesRecommendation">
        <xsd:annotation>
            <xsd:appinfo>SX001G:SparesRecommendation</xsd:appinfo>
        </xsd:annotation>
        <xsd:sequence>
            <xsd:element name="pis" minOccurs="0" maxOccurs="10" nillable="true">
                <xsd:complexType>
                    <xsd:sequence>
                        <!--UML-Attributes-->
                        <xsd:element name="rsq" type="recommendedSparesQuantity" minOccurs="0" nillable="true"/>
                        <!--UML-Interfaces-->
                        <xsd:group ref="serviceApplicabilityItem"/>
                    </xsd:sequence>
                </xsd:complexType>
            </xsd:element>
        </xsd:sequence>
    </xsd:group>
 
    <!-- =============================  UML ATTRIBUTES ====================================== -->
    
    <xsd:complexType name="authorizedLifeValue">
        <xsd:annotation>
            <xsd:appinfo>SX001G:authorizedLifeValue</xsd:appinfo>
        </xsd:annotation>
        <xsd:sequence>
            <xsd:element name="unit" type="unit:timeCycleUnit"/>                            
            <xsd:choice>
                <xsd:sequence>
                    <xsd:element name="value" type="xsd:nonNegativeInteger"/>                                    
                </xsd:sequence>
            </xsd:choice>
        </xsd:sequence>
    </xsd:complexType>
    
    <xsd:complexType name="changeAuthorizationIdentifier">   
        <xsd:annotation>
            <xsd:appinfo>SX001G:changeAuthorizationIdentifier</xsd:appinfo>
        </xsd:annotation>
        <xsd:sequence>
            <xsd:element name="id">
                <xsd:simpleType>
                    <xsd:restriction base="nonEmptyString">
                        <xsd:maxLength value="20"/>
                    </xsd:restriction>
                </xsd:simpleType>
            </xsd:element> 
            <xsd:element name="class" type="value:changeAuthorizationIdentifierClassValues" minOccurs="0" nillable="true" default="CAN"/> 
        </xsd:sequence>
    </xsd:complexType>
    
    <xsd:complexType name="contractorRepairTurnAroundTime">
        <xsd:annotation>
            <xsd:appinfo>SX001G:contractorRepairTurnAroundTime</xsd:appinfo>
        </xsd:annotation>
        <xsd:sequence>
            <xsd:element name="unit" type="unit:timeUnit" default="DAY"/>
            <xsd:element name="value">
                <xsd:simpleType>
                    <xsd:restriction base="xsd:nonNegativeInteger">
                        <xsd:maxInclusive value="999"/>
                    </xsd:restriction>
                </xsd:simpleType>
            </xsd:element>
        </xsd:sequence>
    </xsd:complexType>
    
    <xsd:simpleType name="hardwarePartCalibrationRequirement">
        <xsd:annotation>
            <xsd:appinfo>SX001G:hardwarePartCalibrationRequirement</xsd:appinfo>
        </xsd:annotation>
        <xsd:restriction base="xsd:boolean"/>
    </xsd:simpleType>
    
    <xsd:simpleType name="hardwarePartElectromagneticIncompatible">
        <xsd:annotation>
            <xsd:appinfo>SX001G:hardwarePartElectromagneticIncompatible</xsd:appinfo>
        </xsd:annotation>
        <xsd:restriction base="xsd:boolean"/>
    </xsd:simpleType>
    
    <xsd:simpleType name="hardwarePartElectromagneticSensitive">
        <xsd:annotation>
            <xsd:appinfo>SX001G:hardwarePartElectromagneticSensitive</xsd:appinfo>
        </xsd:annotation>
        <xsd:restriction base="xsd:boolean"/>
    </xsd:simpleType>
    
    <xsd:simpleType name="hardwarePartElectrostaticSensitive">
        <xsd:annotation>
            <xsd:appinfo>SX001G:hardwarePartElectrostaticSensitive</xsd:appinfo>
        </xsd:annotation>
        <xsd:restriction base="xsd:boolean"/>
    </xsd:simpleType>	
    
    <xsd:complexType name="hardwarePartFitmentLevel">
        <xsd:annotation>
            <xsd:appinfo>SX001G:hardwarePartFitmentLevel</xsd:appinfo>
        </xsd:annotation>
        <xsd:sequence>
            <xsd:element name="code" type="value:hardwarePartFitmentLevelCodeValues"/>
        </xsd:sequence>
    </xsd:complexType>
    
    <xsd:complexType name="hardwarePartHazardousClass">
        <xsd:annotation>
            <xsd:appinfo>SX001G:hardwarePartHazardousClass</xsd:appinfo>
        </xsd:annotation>
        <xsd:sequence>
            <xsd:element name="code" type="value:hardwarePartHazardousClassCodeValues"/>
        </xsd:sequence>
    </xsd:complexType>
    
    <xsd:simpleType name="hardwarePartMagneticSensitive">
        <xsd:annotation>
            <xsd:appinfo>SX001G:hardwarePartMagneticSensitive</xsd:appinfo>
        </xsd:annotation>
        <xsd:restriction base="xsd:boolean"/>
    </xsd:simpleType>
    
    <xsd:complexType name="hardwarePartPackagedSize">
        <xsd:annotation>
            <xsd:appinfo>SX001G:hardwarePartPackagedSize</xsd:appinfo>
        </xsd:annotation>
        <xsd:sequence>
            <xsd:element name="length" type="lengthDimension">
                <xsd:annotation>
                    <xsd:appinfo>SX001D:length</xsd:appinfo>
                </xsd:annotation>
            </xsd:element>
            <xsd:choice>
                <xsd:sequence>
                    <xsd:element name="width" type="lengthDimension">
                        <xsd:annotation>
                            <xsd:appinfo>SX001D:width</xsd:appinfo>
                        </xsd:annotation>
                    </xsd:element>
                    <xsd:element name="height" type="lengthDimension">
                        <xsd:annotation>
                            <xsd:appinfo>SX001D:height</xsd:appinfo>
                        </xsd:annotation>
                    </xsd:element>
                </xsd:sequence>
                <xsd:sequence>
                    <xsd:element name="diameter" type="lengthDimension">
                        <xsd:annotation>
                            <xsd:appinfo>SX001D:diameter</xsd:appinfo>
                        </xsd:annotation>
                    </xsd:element>
                </xsd:sequence>
            </xsd:choice>
        </xsd:sequence>
    </xsd:complexType>
    
    <xsd:complexType name="hardwarePartPackagedWeight">
        <xsd:annotation>
            <xsd:appinfo>SX001G:hardwarePartPackagedWeight</xsd:appinfo>
        </xsd:annotation>
        <xsd:sequence>
            <xsd:element name="unit" type="unit:massUnit"/>
            <xsd:element name="value" type="xsd:nonNegativeInteger"/>
        </xsd:sequence>
    </xsd:complexType>
    
    <xsd:complexType name="hardwarePartPackagingRequirement">
        <xsd:annotation>
            <xsd:appinfo>SX001G:hardwarePartPackagingRequirement</xsd:appinfo>
        </xsd:annotation>
        <xsd:sequence>
            <xsd:element name="code" type="value:hardwarePartPackagingRequirementCodeValues"/>
        </xsd:sequence>
    </xsd:complexType>
    
    <xsd:complexType name="hardwarePartPilferageClass">
        <xsd:annotation>
            <xsd:appinfo>SX001G:hardwarePartPilferageClass</xsd:appinfo>
        </xsd:annotation>
        <xsd:sequence>
            <xsd:element name="code" type="value:hardwarePartPilferageClassCodeValues"/>
        </xsd:sequence>
    </xsd:complexType>
    
    <xsd:simpleType name="hardwarePartPoolItemCandidate">
        <xsd:annotation>
            <xsd:appinfo>SX001G:harwarePartPoolItemCandidate</xsd:appinfo>
        </xsd:annotation>
